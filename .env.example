# Runtime database URL for FastAPI async SQLAlchemy
POSTGRES_URL=postgresql+asyncpg://user:password@host:5432/database

# Sync database URL for Alembic migrations
SQLALCHEMY_URL=postgresql://user:password@host:5432/database

# Local development only
FASTAPI_DEV=1

# Keep disabled in app containers; use external cron/job for retraining
RUN_RETRAINER=0

# Usually keep off in production; use Alembic instead
ALLOW_SCHEMA_AUTOCREATE=0

# Optional, only if using remote MLflow
MLFLOW_TRACKING_URI=
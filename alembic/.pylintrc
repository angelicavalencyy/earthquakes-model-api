# Pylint configuration for Alembic migrations
# Disable `no-member` because Alembic's autogenerated migration code and runtime
# Alembic/SQLAlchemy objects often use dynamic attributes that trigger false-positives.

[MASTER]
# when linting files in alembic/, allow imports from project root
init-hook='import sys, os; sys.path.insert(0, os.path.abspath(".."))'

[MESSAGES CONTROL]
disable=no-member

[REPORTS]
reports=no

[FORMAT]
max-line-length=100
